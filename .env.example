# Discourse API Configuration
# Required for contact form submission

# Your Discourse instance hostname (without https://)
DISCOURSE_HOST=forum.bettertransportqueensland.org

# API Key generated in Discourse Admin > API > New API Key
DISCOURSE_API_KEY=

# Username of the Discourse user that will create the topics
DISCOURSE_API_USERNAME=system

# Optional: Category ID where contact form submissions should be posted
# If not set, topics will be created in the default category
DISCOURSE_CONTACT_CATEGORY_ID=68
